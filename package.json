{
  "name": "flashpoint-dashboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "preinstall": "node scripts/check-node.js",
    "clean": "node scripts/clean-next.js",
    "dev:reset": "node scripts/dev-reset.js",
    "dev": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --turbo -p 3000",
    "dev:webpack": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev",
    "build": "node --max-old-space-size=6144 node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "node scripts/copy-tinymce.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/cache": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "6.4.1",
    "@mui/material": "^6.4.1",
    "@mui/material-nextjs": "^9.0.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tinymce/tinymce-react": "^6.3.0",
    "isomorphic-dompurify": "^3.9.0",
    "next": "^15.1.3",
    "nodemailer": "^8.0.5",
    "nprogress": "^0.2.0",
    "plyr": "^3.8.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.4.1",
    "react-simple-maps": "^3.0.0",
    "tinymce": "^8.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.0",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/react-simple-maps": "^3.0.6",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "typescript": "^5.7.2"
  }
}
